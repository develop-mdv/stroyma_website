# Django core
SECRET_KEY=replace-me-in-production
# Старые SECRET_KEY через запятую (ротация ключей, опционально)
# SECRET_KEY_FALLBACKS=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# URL админки (например admin/); не публикуйте в открытом виде
ADMIN_URL=admin/

# Email для уведомлений о заказах и заявках (пусто = как EMAIL_HOST_USER)
# ORDER_NOTIFY_EMAIL=orders@example.com

# PostgreSQL
DB_NAME=stroyma
DB_USER=stroyma
DB_PASSWORD=stroyma
DB_HOST=localhost
DB_PORT=5432

# SMTP (Яндекс)
EMAIL_HOST_USER=example@yandex.ru
EMAIL_HOST_PASSWORD=
# Сек. ожидания ответа SMTP (таймаут в потоке отправки, см. products/views.py)
# EMAIL_TIMEOUT=20

# Опционально: кеш Redis (иначе LocMemCache)
# REDIS_URL=redis://127.0.0.1:6379/1

# Продакшен-HTTPS (применяются только при DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=2592000

# django-axes: блокировка брутфорса входа
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_HOURS=1
